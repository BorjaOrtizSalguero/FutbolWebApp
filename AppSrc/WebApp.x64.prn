37781>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37784>>>        WebSet pbRender of oNewButton to True
37785>>>        WebSet pbRender of oDetailButton to True
37786>>>
37786>>>        Case Begin
37786>>>            Case (NavigateData.eNavigateType = nfFromParent)
37788>>>                // If from parent, this is a constrained drill down
37788>>>                Case Break
37789>>>
37789>>>            Case (NavigateData.eNavigateType = nfFromChild)
37792>>>                // If from child, this is a probably a parent lookup from a Zoom
37792>>>                Case Break
37793>>>
37793>>>            Case (NavigateData.eNavigateType = nfFromMain)
37796>>>                // If from main, this is a probably a main-file lookup from a Zoom
37796>>>                WebSet pbRender of oDetailButton to False
37797>>>                Case Break
37798>>>
37798>>>            Case Else // must be nfUndefined
37798>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
37798>>>
37798>>>        Case End
37798>>>
37798>>>    End_Procedure
37799>>>
37799>>>
37799>>>End_Object 
