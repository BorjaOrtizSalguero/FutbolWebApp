37628>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37631>>>        WebSet pbRender of oNewButton to True
37632>>>        WebSet pbRender of oDetailButton to True
37633>>>
37633>>>        Case Begin
37633>>>            Case (NavigateData.eNavigateType = nfFromParent)
37635>>>                // If from parent, this is a constrained drill down
37635>>>                Case Break
37636>>>
37636>>>            Case (NavigateData.eNavigateType = nfFromChild)
37639>>>                // If from child, this is a probably a parent lookup from a Zoom
37639>>>                Case Break
37640>>>
37640>>>            Case (NavigateData.eNavigateType = nfFromMain)
37643>>>                // If from main, this is a probably a main-file lookup from a Zoom
37643>>>                WebSet pbRender of oDetailButton to False
37644>>>                Case Break
37645>>>
37645>>>            Case Else // must be nfUndefined
37645>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
37645>>>
37645>>>        Case End
37645>>>
37645>>>    End_Procedure
