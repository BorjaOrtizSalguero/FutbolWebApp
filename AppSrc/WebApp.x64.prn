38726>>>                // If from parent, this is a constrained drill down.
38726>>>                Case Break
38727>>>
38727>>>            Case (NavigateData.eNavigateType = nfFromChild)
38730>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38730>>>                Case Break
38731>>>
38731>>>            Case Else // must be nfUndefined
38731>>>
38731>>>        Case End
38731>>>
38731>>>        Send SetActionButtons
