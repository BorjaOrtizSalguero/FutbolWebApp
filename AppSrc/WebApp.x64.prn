37826>>>        WebSet pbRender of oNewButton to True
37827>>>        WebSet pbRender of oDetailButton to True
37828>>>
37828>>>        Case Begin
37828>>>            Case (NavigateData.eNavigateType = nfFromParent)
37830>>>                // If from parent, this is a constrained drill down
37830>>>                Case Break
37831>>>
37831>>>            Case (NavigateData.eNavigateType = nfFromChild)
37834>>>                // If from child, this is a probably a parent lookup from a Zoom
37834>>>                Case Break
37835>>>
37835>>>            Case (NavigateData.eNavigateType = nfFromMain)
37838>>>                // If from main, this is a probably a main-file lookup from a Zoom
37838>>>                WebSet pbRender of oDetailButton to False
37839>>>                Case Break
37840>>>
37840>>>            Case Else // must be nfUndefined
37840>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
37840>>>
37840>>>        Case End
37840>>>
37840>>>    End_Procedure
